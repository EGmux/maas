#cloud-config
autoinstall:
  version: 1

  identity:
    hostname: ubuntu
    username: ubuntu
    password: "$6$canonical.$0zWaW71A9ke9ASsaOcFTdQ2tx1gSmLxMPrsH0rF0Yb.2AEKNPV1lrF94n6YuPJmnUy2K2/JSDtxuiBDey6Lpa/"
  
  keyboard:
    layout: us
    variant: dvorak
  
  ssh:
    install-server: true
  
  storage:
    grub:
      update_nvram: true
    swap:
      size: 0
    layout:
      name: lvm
      sizing-policy: all
  
  # Only MAAS dependencies - nothing else
  packages:
    - postgresql
    - postgresql-contrib
    - git
    - python3-dev
    - python3-pip
    - python3-venv
    - build-essential
    - libpq-dev
    - libyaml-dev
    - npm
    - nodejs
  
  package_update: true
  package_upgrade: true

  late-commands:
    # Passwordless sudo
    - curtin in-target --target=/target -- sh -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ubuntu'
    - curtin in-target --target=/target -- chmod 440 /etc/sudoers.d/ubuntu
    - cp /cdrom/setup-cloudinit.sh /target/tmp/setup-cloudinit.sh
    - curtin in-target --target=/target -- chmod +x /tmp/setup-cloudinit.sh
    - curtin in-target --target=/target -- /tmp/setup-cloudinit.sh
