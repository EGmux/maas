#cloud-config
autoinstall:
  version: 1

  identity:
    hostname: ubuntu
    username: ubuntu
    password: "$6$canonical.$0zWaW71A9ke9ASsaOcFTdQ2tx1gSmLxMPrsH0rF0Yb.2AEKNPV1lrF94n6YuPJmnUy2K2/JSDtxuiBDey6Lpa/"

  keyboard:
    layout: us
    variant: dvorak

  ssh:
    install-server: true
    allow-pw: true

  storage:
    grub:
      update_nvram: true
    swap:
      size: 0
    layout:
      name: lvm
      sizing-policy: all

  network:
    version: 2
    ethernets:
      en_interfaces:
        match:
          name: "en*"
        dhcp4: true
        optional: true

  package_update: true
  package_upgrade: true

  late-commands:
    - curtin in-target --target=/target -- sh -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ubuntu'
    - curtin in-target --target=/target -- chmod 440 /etc/sudoers.d/ubuntu
